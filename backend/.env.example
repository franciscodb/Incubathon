# ------------------------------------------------------------------
# Variables de entorno del backend "CumplIA"
# Copia este archivo a .env y rellena los valores reales.
# ------------------------------------------------------------------

# Supabase (dejar vacío para correr en modo MOCK sin base de datos)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=documents

# Origen del frontend permitido por CORS (usar * solo para demo)
FRONTEND_ORIGIN=http://localhost:5173
# URL pública del frontend, usada para las redirecciones de Stripe Checkout.
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------
# Stripe (suscripciones). Dejar vacío para checkout SIMULADO en la demo.
# Con estas llaves, el cobro es real vía Stripe Checkout + webhook.
#   - Webhook a configurar en Stripe: POST {BACKEND_URL}/billing/webhook
#   - Eventos: checkout.session.completed, customer.subscription.deleted
# ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Fuerza el modo mock aunque existan credenciales de Supabase.
# El backend también entra en modo mock automáticamente si SUPABASE_URL está vacío.
USE_MOCK=true
